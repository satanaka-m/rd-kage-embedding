name: rd-kage-sigreg

entry_points:
  parse_kage:
    parameters:
      config:
        description: "Path to config file"
        type: string
        default: "conf/config.yaml"
      kage_dump_dir:
        description: "Path to KAGE dump directory"
        type: string
        default: "data/kage_dump"
    command: "python prepare_parse_kage_tsv.py --config {config} --kage_dump_dir {kage_dump_dir}"

  check_data:
    parameters:
      config:
        description: "Path to config file"
        type: string
        default: "conf/config.yaml"
      output_strokes:
        description: "Output stroke visualization"
        type: bool
        default: false
    command: "python check_data.py --config {config} --output_strokes {output_strokes}"

  train:
    parameters:
      config:
        description: "Path to configuration file"
        type: string
        default: "conf/config.yaml"
    command: "python train.py --config {config}"

  visualize_knn:
    parameters:
      config:
        description: "Path to configuration file"
        type: string
        default: "conf/config.yaml"
      checkpoint:
        description: "Path to model checkpoint"
        type: string
      output_dir:
        description: "Directory to save visualization images"
        type: string
        default: "outputs/knn"
      top_k:
        description: "Number of nearest neighbors to visualize"
        type: int
        default: 20
      num:
        description: "Number of random query samples"
        type: int
        default: 20
      batch_size:
        description: "Batch size for embedding extraction"
        type: int
        default: 64
      seed:
        description: "Random seed for query sampling"
        type: int
        default: 42
    command: "python visualize_knn.py --config {config} --checkpoint {checkpoint} --output-dir {output_dir} --top-k {top_k} --num {num} --batch-size {batch_size} --seed {seed}"
